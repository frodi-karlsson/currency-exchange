<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/design-system.css">
  {{- if scripts }}
  {{- for script of scripts }}
  <script type="module" src="{{ script }}" defer></script>
  {{- /for }}
  {{- /if }}
</head>
<body>
  <div class="stripes-bg"></div>
  <main class="container">
    {{ content }}
  </main>
</body>
</html>